 {


  "name": "whatuni-review-web-app",


  "version": "0.0.0",


  "scripts": {


	"ng": "ng",


	"start:dev": "ng serve -c=dev",


	"start:test": "ng serve -c=test",


	"start:live": "ng serve -c=production",


	"build:dev": "ng build --prod --c dev",


	"build:test": "ng build --prod --c test",


	"build:live": "ng build --prod --c production",


	"lint-test": "ng lint",


	"e2e": "ng e2e",


	"compile:server": "webpack --config webpack.server.config.js --progress",


	"dev:ssr": "ng run whatuni-review-web-app:serve-ssr",


	"serve:ssr": "node dist/whatuni-review-web-app/server/main.js",


	"prerender": "ng run whatuni-review-web-app:prerender",


	"lint": "eslint -f html -o ./reports/eslint-report.html --color ./",


	"lint:dev": "eslint -f html -o ./reports/eslint-reporzt.html --color ./ --plugin file-progress --rule \"file-progress/activate: 1\"",


	"lint:fix": "eslint --fix ./",


	"test": "jest",


	"test:watch": "jest --watch",


	"test:coverage": "jest --coverage",


	"build:dev:browser:ssr": "ng build --base-href /university-reviews --deploy-url /university-reviews/ --c dev",


	"build:dev:server:ssr": "ng run whatuni-review-web-app:serverless:dev",


	"build:dev:ssr": "npm run build:dev:browser:ssr && npm run build:dev:server:ssr",


	"build:test:browser:ssr": "ng build --base-href /university-reviews --deploy-url /university-reviews/ --c test",


	"build:test:server:ssr": "ng run whatuni-review-web-app:serverless:test",


	"build:test:ssr": "npm run build:test:browser:ssr && npm run build:test:server:ssr",


	"build:browser:ssr": "ng build --base-href /university-reviews --deploy-url /university-reviews/ --c production",


	"build:server:ssr": "ng run whatuni-review-web-app:serverless:production",


	"build:ssr": "npm run build:browser:ssr && npm run build:server:ssr",


	"build:dev:browser:serverless": "ng build --base-href /university-reviews --deploy-url /university-reviews/ --c dev",


	"build:dev:server:serverless": "ng run whatuni-review-web-app:serverless:dev",


	"build:dev:serverless": "npm run build:dev:browser:serverless && npm run build:dev:server:serverless",


	"build:test:browser:serverless": "ng build --base-href /university-reviews --deploy-url /university-reviews/ --c test",


	"build:test:server:serverless": "ng run whatuni-review-web-app:serverless:test",


	"build:test:serverless": "npm run build:test:browser:serverless && npm run build:test:server:serverless",


	"build:browser:serverless": "ng build --base-href /university-reviews --deploy-url /university-reviews/ --c production",


	"build:server:serverless": "ng run whatuni-review-web-app:serverless:production",


	"build:serverless": "npm run build:browser:serverless && npm run build:server:serverless",


	"deploy:serverless": "serverless deploy",


	"build:deploy:serverless": "npm run build:serverless && npm run deploy",


	"build:client-and-server-bundles": "ng build --prod && ng run whatuni-review-web-app:server:production --bundleDependencies all",


	"serve:serverless": "serverless offline start"


  },


  "private": true,


